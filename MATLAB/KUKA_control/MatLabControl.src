&ACCESS RVP
&REL 4
DEF MatlabControl()
    DECL INT I           ; 

    WAIT FOR $MOVE_ENABLE     ; Safety: wait for drives enabled & mode ok

    ; Safe init - resets defaults
    BAS(#INITMOV,0)

    ; Set safe initial velocities + accelerations (100%)
    FOR I = 1 TO 6
        $VEL_AXIS[I] = 100
        $ACC_AXIS[I] = 100
    ENDFOR

    PTP XHOME                 ; Move to home (assuming XHOME is declared somewhere)

    ; Main loop
    LOOP
        WAIT FOR $MOVE_ENABLE   ; Re-check safety

        IF move_trigger THEN
            ; fast move (100%)
            FOR I = 1 TO 6
                $VEL_AXIS[I] = 100
                $ACC_AXIS[I] = 100
            ENDFOR

            ; Tiny settle time for motion planner (helps stability)
            WAIT SEC 0.02

            PTP target_pos
            move_trigger = FALSE
        ENDIF

        WAIT SEC 0.01              ; CPU-friendly delay
    ENDLOOP
END